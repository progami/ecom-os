aws_region  = "us-east-1"
project     = "ecom-os"
environment = "prod"

portal_domain  = "ecomos.targonglobal.com"
website_domain = "www.targonglobal.com"
cookie_domain = ".targonglobal.com"

# ECS capacity
ecs_instance_type    = "t3.medium"
ecs_min_size         = 1
ecs_max_size         = 2
ecs_desired_capacity = 1

# RDS configuration
db_instance_class     = "db.t4g.small"
db_allocated_storage  = 20
db_engine_version     = "16.4"
db_username           = "portal_admin"
db_password           = "change-me"
db_backup_retention   = 3
db_skip_final_snapshot = true

image_tag = "latest"

# Runtime environment overrides (maps)
ecomos_environment = {
  NEXTAUTH_SECRET   = "set-me"
  PORTAL_AUTH_SECRET = "set-me"
}

wms_environment = {
  NEXTAUTH_SECRET   = "set-me"
  PORTAL_AUTH_SECRET = "set-me"
}

xplan_environment = {
  NEXTAUTH_SECRET   = "set-me"
  PORTAL_AUTH_SECRET = "set-me"
}

website_environment = {}
